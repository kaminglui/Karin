# Karin deploy .env — copy to .env and uncomment ONE COMPOSE_FILE line.
#
#   cp .env.example .env
#   # edit, then:
#   docker compose up -d
#
# COMPOSE_FILE chains the base compose file with an overlay specific
# to your host platform. It's a colon-separated list (Windows: semicolon).
#
# Voice (TTS/STT) stays OFF by default. On Jetson Orin Nano 8 GB the LLM
# and GPT-SoVITS cannot co-exist in memory — do NOT flip KARIN_TTS_ENABLED
# on here unless you have (a) Orin NX 16 GB or larger AND are running
# sovits locally, OR (b) PC-TTS offload configured (KARIN_TTS_BASE_URL
# pointing at a remote GPT-SoVITS over Tailscale; see deploy/pc-tts/).
#
# Every var below is read by code. Defaults that work out-of-the-box are
# documented inline so you only need to set the ones you actually want
# to change.

# ----- Platform (pick one) ----------------------------------------------------

# --- Jetson Orin (ARM64 + JetPack 6): THE deploy target -----------------------
# COMPOSE_FILE=deploy/docker-compose.yml:deploy/docker-compose.jetson.yml

# --- Desktop Linux with NVIDIA GPU (dev / debug) ------------------------------
# COMPOSE_FILE=deploy/docker-compose.yml:deploy/docker-compose.gpu.yml

# --- CPU-only (slow but works anywhere for a quick sanity check) --------------
COMPOSE_FILE=deploy/docker-compose.yml


# ----- LLM model + memory budget --------------------------------------------
#
# Production model on Jetson Orin Nano 8 GB is `karin-tuned:latest` — an
# iter-3 LoRA merged on top of mannix/llama3.1-8b-abliterated:tools-q4_k_m
# (~4.9 GB). Built on the Jetson by deploy/setup.sh if `karin-lora.gguf`
# is present, or pulled/built manually per sft/colab_sft.ipynb § 9. That
# is the model tool-routing, reply composition, and the 135-case eval
# score (93.3% / 91.9% / 59.2%) are all measured against.
#
# deploy/setup.sh writes KARIN_LLM_MODEL=karin-tuned:latest to deploy/.env
# once the tag exists. Leave it unset only when you intentionally want the
# checked-in config/assistant.yaml fallback, or set it explicitly:
#   KARIN_LLM_MODEL=karin-tuned:latest        (production — Orin Nano 8 GB)
#
# Alternatives (pre-LoRA baselines — lower routing accuracy, use only
# when karin-tuned is not available or for A/B testing):
#   KARIN_LLM_MODEL=qwen2.5:3b                (smallest that still routes OK)
#   KARIN_LLM_MODEL=huihui_ai/qwen3.5-abliterated:4b   (Orin NX 16 GB or desktop)
# See config/models.yaml for the full tuned list (max_per_tool, num_ctx, etc.).

# Ollama HTTP endpoint (default config/assistant.yaml: http://127.0.0.1:11434)
# Override when Ollama runs on a different host or non-default port.
# KARIN_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Higher timeout for slow first-token cold loads on Jetson. 300s is the
# bridge container's hard cap; raise here if you have an even slower box.
# KARIN_LLM_TIMEOUT=300

# Drop num_ctx to save KV-cache memory (each 1024 ctx ≈ 200 MB on an 8B
# model at fp16; q8_0 halves that). 2048 is what karin-tuned ships with
# in config/models.yaml — enough for the system prompt + tool schemas
# with compaction handling multi-turn overflow. Only override if you
# know your model needs more.
# KARIN_NUM_CTX=2048

# Sentence-embedding model used by the L2d embedding fallback classifier.
# Default is "BAAI/bge-small-en-v1.5"; the fastembed runtime auto-loads it.
# Set to "" to disable embedding fallback entirely (regex+spaCy only).
# KARIN_EMBED_MODEL=BAAI/bge-small-en-v1.5

# Web port the FastAPI app binds. Default 80 inside the container; the
# Tailscale Serve front-end proxies 443 → this.
# KARIN_WEB_PORT=80


# ----- STT (speech-to-text) -------------------------------------------------
#
# OFF by default. Path 1 (text-only) needs nothing here. Path 2 (local
# faster-whisper on Jetson CPU) flips KARIN_STT_ENABLED=true. Path 3
# (offload to a PC) sets KARIN_STT_BASE_URL instead.
#
# Defaults (config/assistant.yaml) are memory-first: `base.en` on CPU.
# Uses ~700 MB of unified memory on Jetson Orin Nano. Drop to `tiny.en`
# (~400 MB) if `base.en` exhausts the ~600 MiB headroom next to
# karin-tuned — RUNBOOK.md § STT recommends `tiny.en` for safety on
# Orin Nano 8 GB.
#   KARIN_STT_MODEL=tiny.en | base.en | small.en
#   KARIN_STT_DEVICE=cpu | cuda
#   KARIN_STT_COMPUTE_TYPE=int8 (CPU) | int8_float16 (CUDA Jetson) | float16 (big GPU)
#   KARIN_STT_ENABLED=true | false
#   KARIN_STT_LANGUAGE=en           # ISO-639-1 hint; "" lets Whisper detect
#   KARIN_STT_MAX_SECONDS=30        # reject uploads longer than this
#   KARIN_STT_NUM_WORKERS=1         # ctranslate2 worker threads (CPU)
#
# Note for Jetson: PyPI's ARM64 ctranslate2 wheel is CPU-only. Keep
# device=cpu unless you've built ctranslate2 from source against
# JetPack's CUDA AND have a Jetson with spare VRAM.

# STT offload to a PC (mirror of KARIN_TTS_BASE_URL). The sidecar at
# deploy/pc-tts/tts_server.py serves both /tts and /transcribe from one
# process, so both env vars typically point at the same host+port.
# Setting this skips the local faster-whisper load entirely.
# KARIN_STT_BASE_URL=http://<pc-tailscale-ip>:9880


# ----- TTS (speech synthesis) -----------------------------------------------
#
# OFF by default. Flip on only with PC-TTS offload (Path 3) on Orin Nano 8
# GB; flip on with KARIN_LOCAL_SOVITS=yes only on Orin NX 16 GB or larger.
#
# KARIN_TTS_ENABLED=true
# KARIN_TTS_BASE_URL=http://<pc-tailscale-ip>:9880
# KARIN_TTS_MAX_CHARS=600          # truncate replies before synthesis
# KARIN_TTS_REF=                   # override character's ref.wav per request
# KARIN_VOICE_CPU_THREADS=2        # local sovits CPU thread cap


# ----- Active character / voice / face --------------------------------------
#
# Selects one of the bundles under characters/<name>/. Falls back to
# characters/default/ if unset or missing. The sidebar dropdown writes
# this atomically via POST /api/tts/voice, so the env var is mainly for
# headless / first-boot defaults.
#
# KARIN_CHARACTER=karin            # active character folder name
# KARIN_FACE_CHOICE=               # override face.json name (rare)


# ----- Profile (multi-user) -------------------------------------------------
#
# Picks which data/profiles/<name>/ tree to use. Tailscale IP routing
# auto-switches per device; this is the manual override for
# single-tenant deploys or tests.
#
# KARIN_PROFILE=default


# ----- User location (geocoding fallback for weather / alerts) --------------
#
# When set, weather/alerts skip the IP-geolocation call. All optional —
# unset values are fine, the bridge will look them up from ipwho.is.
#
# KARIN_USER_CITY=Brooklyn
# KARIN_USER_REGION=NY
# KARIN_USER_COUNTRY=US
# KARIN_USER_LAT=40.6782
# KARIN_USER_LON=-73.9442
# KARIN_USER_TZ=America/New_York


# ----- Optional upstream API keys -------------------------------------------
#
# Three-source resolution: env var (here) wins, then per-profile
# preferences.json `api_keys` block (Settings UI), then no-key fallback.
# Most are optional — unset means "use the no-key path" (e.g. DDG instead
# of Brave, NWS instead of Open-Meteo, Wikipedia instead of WolframAlpha).
#
# KARIN_API_KEY_BRAVE_SEARCH=      # web_search backend (otherwise DuckDuckGo)
# KARIN_API_KEY_OPENAI=            # only used by sft/ helpers, never the bridge
# KARIN_NEWSAPI_KEY=               # supplements RSS feeds in news subsystem
# KARIN_CDC_APP_TOKEN=             # CDC Socrata API (mortality fetcher; optional)
# KARIN_CENSUS_API_KEY=            # Census ACS county fetcher (required for ACS)
# KARIN_FBI_API_KEY=               # FBI Crime Data Explorer (required for UCR)
# KARIN_EIA_API_KEY=               # EIA gasoline override fetcher


# ----- Notifications --------------------------------------------------------
#
# Pollers (alerts, trackers shocks, news) push events to whichever channel
# URL is set. Both are optional; with neither set, notifications stay
# in-app only (Alerts panel + sidebar pulse).
#
# KARIN_NOTIFICATIONS=true
# KARIN_NOTIFY_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...
# KARIN_NOTIFY_NTFY_TOPIC=https://ntfy.sh/your-private-topic-name


# ----- Subsystem feature flags ----------------------------------------------
#
# Most subsystems toggle in config/features.yaml; these are the ones the
# code also accepts as env overrides for CI / compose deploys.
#
# KARIN_BANDIT=true                # learned-keyword bandit on news
# KARIN_REMINDERS_LLM_TOOL=true    # expose schedule_reminder to the LLM
# KARIN_ALERTS_TRAVEL_ADVISORY=true # include US State Dept advisories


# ----- Calendar (optional) --------------------------------------------------
#
# ICS feed URLs for the calendar subsystem (digest + reminder hints).
# Both optional; either both, one, or neither.
#
# KARIN_CALENDAR=true
# KARIN_CALENDAR_PERSONAL_URL=https://calendar.google.com/calendar/ical/.../basic.ics
# KARIN_CALENDAR_WORK_URL=https://outlook.office365.com/owa/calendar/.../calendar.ics


# ----- Internal / advanced (rarely changed) ---------------------------------
#
# KARIN_DOCKER_SOCK=/var/run/docker.sock   # for sovits container restart hook
# KARIN_SOVITS_CONTAINER=sovits            # container name to restart
